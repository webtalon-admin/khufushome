# Environment: 'local' or 'prod'
# Controls which block of config/env.yaml is loaded.
# Defaults to 'local' if not set. Override with: KHUFUS_ENV=prod pnpm dev
KHUFUS_ENV=local

# Supabase secrets (URLs come from config/env.yaml, only keys go here)
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# Home Assistant
HA_ACCESS_TOKEN=

# MQTT
MQTT_USERNAME=
MQTT_PASSWORD=
