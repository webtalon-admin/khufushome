{
  "name": "khufushome",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "KHUFUS_ENV=${KHUFUS_ENV:-local} turbo dev",
    "dev:prod": "KHUFUS_ENV=prod turbo dev",
    "build": "turbo build",
    "build:prod": "KHUFUS_ENV=prod turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration new",
    "db:status": "supabase status",
    "pipeline:seed": "uv run --project scripts/super-pipeline python scripts/super-pipeline/seed.py",
    "pipeline:apra": "uv run --project scripts/super-pipeline python scripts/super-pipeline/ingest_apra.py",
    "pipeline:yoursuper": "curl -s -X POST http://127.0.0.1:54321/functions/v1/yoursuper-refresh -H \"Authorization: Bearer ${SUPABASE_ANON_KEY:-sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH}\" -H \"Content-Type: application/json\"",
    "pipeline:btc-price": "curl -s -X POST http://127.0.0.1:54321/functions/v1/btc-price-refresh -H \"Authorization: Bearer ${SUPABASE_ANON_KEY:-sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH}\" -H \"Content-Type: application/json\"",
    "functions:serve": "supabase functions serve --no-verify-jwt"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "supabase": "^2.78.1",
    "turbo": "^2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "supabase"
    ]
  }
}
